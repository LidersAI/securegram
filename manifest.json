{
  "name": "LIDERS CHAT",
  "short_name": "LIDERS CHAT",
  "description": "Защищённый P2P мессенджер с E2E шифрованием. Без номера телефона.",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "background_color": "#000000",
  "theme_color": "#0d1a2e",
  "orientation": "portrait-primary",
