      "description": "Начать новый чат",
      "icons": [{"src": "icon-96.png", "sizes": "96x96"}]
    },
    {
      "name": "Контакты",
      "short_name": "Контакты",
      "url": "/?tab=contacts",
      "description": "Открыть список контактов",
      "icons": [{"src": "icon-96.png", "sizes": "96x96"}]
    }
  ],
  "share_target": {
    "action": "/",
